{
  "name": "kharcha-mini",
  "version": "0.1.0",
  "private": true,
  "description": "Mac mini ingestion pipeline for Kharcha: read iPhone SMS from chat.db, parse bank alerts, store canonical transactions.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "drizzle:generate": "drizzle-kit generate",
    "drizzle:studio": "drizzle-kit studio",
    "ingest": "bun run src/ingest/run.ts",
    "api": "bun run src/api/server.ts",
    "generate-api-token": "bun run src/scripts/generate-api-token.ts",
    "seed:allowlist": "bun run src/scripts/seed-allowlist.ts",
    "toggle-proofread": "bun run src/scripts/toggle-proofread.ts",
    "verify:proofread": "bun run src/scripts/verify-proofread.ts",
    "verify:allowlist": "bun run src/scripts/verify-allowlist.ts",
    "verify:api": "bun run src/scripts/verify-api.ts"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "zod": "^3.25.57"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.2"
  }
}
